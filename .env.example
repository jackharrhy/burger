# burger config. Copy to .env and adjust.

# 4orm OAuth provider (PKCE — no client secret needed)
FOURM_URL=https://4orm.harrhy.xyz
FOURM_CLIENT_ID=burger

# Public URL where this burger server is reachable.
# Local dev: http://localhost:5000
# Production: https://big.burger.beauty
BURGER_URL=http://localhost:5000

# SQLite database path. Defaults to ./data/burger.db when unset.
DB_PATH=./data/burger.db

# production | development. Affects cookie Secure flag and session cookie
# transport. Set to "production" when serving over HTTPS.
NODE_ENV=development
