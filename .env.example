# burger config. Copy to .env and adjust.

# 4orm OAuth provider (PKCE — no client secret needed)
FOURM_URL=https://4orm.harrhy.xyz
FOURM_CLIENT_ID=burger

# Public URL the browser sees. Used for OAuth redirect_uri and cookie scoping.
# In dev: http://localhost:5173 (vite serves the SPA and proxies /auth, /api,
#   /ws to the elysia server on :5000). Cookies set during OAuth callback
#   land on :5173 so subsequent fetches inside the SPA carry them.
# In prod: https://big.burger.beauty (single origin, no proxy).
BURGER_URL=http://localhost:5173

# SQLite database path. Defaults to ./data/burger.db when unset.
DB_PATH=./data/burger.db

# production | development. Affects cookie Secure flag and session cookie
# transport. Set to "production" when serving over HTTPS.
NODE_ENV=development
